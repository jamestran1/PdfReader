<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:pages="clr-namespace:TriThu.Maui.Pages"
             x:Class="TriThu.Maui.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/TriThuTokens.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Value converters used by MainPage -->
            <pages:BoolToNavColorConverter x:Key="BoolToColorConverter"/>
            <pages:NotNullToBoolConverter x:Key="NotNullToBoolConverter"/>
            <pages:ZeroToTrueConverter x:Key="ZeroToTrueConverter"/>
            <pages:InverseBoolConverter x:Key="InverseBoolConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
