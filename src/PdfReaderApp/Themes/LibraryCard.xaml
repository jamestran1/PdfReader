<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Library screen (M3). Nguồn: PDF Reader.dc.html (LIBRARY). -->

    <!-- Tile bìa: bo góc 16, tỉ lệ ~3:4 (đặt Height cố định ở chỗ dùng), đổ bóng tăng khi hover. -->
    <Style x:Key="TriThu.LibraryCard" TargetType="Border">
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Effect" Value="{DynamicResource TriThu.Elevation.E1}"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value><TranslateTransform/></Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Effect" Value="{DynamicResource TriThu.Elevation.E3}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Pill số trang đè góc phải-trên tile: nền tối nhẹ, chữ mono trắng. -->
    <Style x:Key="TriThu.LibraryCard.PagePill" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#59000000"/>
        <Setter Property="Padding" Value="7,3"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="12"/>
    </Style>

    <!-- Chip nhà xuất bản đè góc trái-trên tile: cùng chrome overlay như PagePill (#64). -->
    <Style x:Key="TriThu.LibraryCard.PublisherChip" TargetType="Border">
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="Background" Value="#59000000"/>
        <Setter Property="Padding" Value="7,3"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="VerticalAlignment" Value="Top"/>
        <Setter Property="Margin" Value="12"/>
    </Style>

    <!-- Nút xoá đè góc trái-trên (hiện khi hover card): tròn, nền tối nhẹ, icon trắng. -->
    <Style x:Key="TriThu.LibraryCard.Delete" TargetType="Button">
        <Setter Property="Width" Value="30"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bg" CornerRadius="100" Background="#59000000">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bg" Property="Background" Value="#8C000000"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ô tìm kiếm bo góc nhẹ (không phải oval); chỉ hình thức ở slice này, backend search là issue riêng. -->
    <Style x:Key="TriThu.Library.SearchBox" TargetType="Border">
        <Setter Property="Width" Value="280"/>
        <Setter Property="Height" Value="44"/>
        <Setter Property="CornerRadius" Value="12"/>
        <Setter Property="Background" Value="{DynamicResource TriThu.Brush.SurfaceTonalHigh}"/>
        <Setter Property="Padding" Value="16,0"/>
    </Style>
</ResourceDictionary>
