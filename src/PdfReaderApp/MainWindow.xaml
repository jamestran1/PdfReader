<Window x:Class="PdfReaderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:PdfReaderApp"
        xmlns:viewmodels="clr-namespace:PdfReaderApp.ViewModels"
        xmlns:controls="clr-namespace:PdfReaderApp.Controls"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="800" Width="1200"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <local:RoleToBrushConverter x:Key="RoleToBrushConverter" />
        <local:RoleToAlignConverter x:Key="RoleToAlignConverter" />
        <local:CountToBoolConverter x:Key="CountToBoolConverter" />
        <local:PageDisplayConverter x:Key="PageDisplayConverter" />
        <local:ViewModeToBoolConverter x:Key="ViewModeToBoolConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:CountToInverseVisibilityConverter x:Key="CountToInverseVisibilityConverter" />
        <local:UnixToDateConverter x:Key="UnixToDateConverter" />
        <local:PathToImageConverter x:Key="PathToImageConverter" />
        <local:PageBadgeConverter x:Key="PageBadgeConverter"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <local:DocumentIdToBrushConverter x:Key="DocumentIdToBrushConverter"/>
        <local:DocumentIdToTitleConverter x:Key="DocumentIdToTitleConverter"/>
    </Window.Resources>
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="OemPlus" Command="{Binding ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="Add" Command="{Binding ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="OemMinus" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Modifiers="Control" Key="Subtract" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="PageDown" Command="{Binding NextPageCommand}" />
        <KeyBinding Key="PageUp" Command="{Binding PreviousPageCommand}" />
        <KeyBinding Modifiers="Control" Key="Home" Command="{Binding FirstPageCommand}" />
        <KeyBinding Modifiers="Control" Key="End" Command="{Binding LastPageCommand}" />
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenFileCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{Binding ChatColumnWidth, Mode=TwoWay}"
                              MinWidth="{Binding ChatColumnMinWidth}" MaxWidth="700"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Rail -->
        <materialDesign:ColorZone Grid.Column="0" Mode="PrimaryMid" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Margin="0,20">
                     <materialDesign:PackIcon Kind="FilePdfBox" Width="40" Height="40" HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="60" ToolTip="Thư viện"
                            Command="{Binding ShowLibraryViewCommand}">
                        <materialDesign:PackIcon Kind="BookOpenVariant" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="60" ToolTip="Workspaces"
                            Command="{Binding ShowWorkspacesViewCommand}">
                        <materialDesign:PackIcon Kind="FolderMultipleOutline" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="60" ToolTip="Edit">
                        <materialDesign:PackIcon Kind="Pencil" Width="24" Height="24"/>
                    </Button>
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="60" ToolTip="AI Assistant">
                        <materialDesign:PackIcon Kind="Robot" Width="24" Height="24"/>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,20">
                    <Button Style="{StaticResource MaterialDesignFlatButton}" Foreground="White" Height="60" ToolTip="Settings"
                            Command="{Binding OpenSettingsCommand}">
                        <materialDesign:PackIcon Kind="Settings" Width="24" Height="24"/>
                    </Button>
                </StackPanel>
            </Grid>
        </materialDesign:ColorZone>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Toolbar -->
            <materialDesign:ColorZone Mode="Standard" Padding="16" materialDesign:ElevationAssist.Elevation="Dp2">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Style="{StaticResource MaterialDesignRaisedButton}" 
                                Command="{Binding OpenFileCommand}" 
                                Content="OPEN PDF"
                                materialDesign:ButtonAssist.CornerRadius="20"/>

                        <!-- Nút điều khiển đọc: chỉ hiện khi đang đọc tài liệu (ẩn ở Thư viện/Workspaces) -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsReadingDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="16,0" />
                        
                        <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding ZoomOutCommand}" ToolTip="Zoom Out">
                            <materialDesign:PackIcon Kind="Minus" />
                        </Button>
                        <Slider Width="120" VerticalAlignment="Center" Minimum="0.4" Maximum="4.0"
                                Value="{Binding ZoomLevel, Mode=TwoWay}"
                                TickFrequency="0.1" IsSnapToTickEnabled="False" ToolTip="Zoom"/>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding ZoomInCommand}" ToolTip="Zoom In">
                            <materialDesign:PackIcon Kind="Plus" />
                        </Button>
                        <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="8,0" Width="50" TextAlignment="Center" FontWeight="Bold"/>

                        <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="16,0" />

                        <!-- View mode toggles: IsChecked OneWay (display) + Command sets the mode,
                             so clicking always selects a mode and the active one cannot be unchecked. -->
                        <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}" ToolTip="Single Page"
                                      IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=SinglePage, Mode=OneWay}"
                                      Command="{Binding SetViewModeCommand}" CommandParameter="SinglePage">
                            <materialDesign:PackIcon Kind="FileOutline" />
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}" ToolTip="Continuous"
                                      IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=Continuous, Mode=OneWay}"
                                      Command="{Binding SetViewModeCommand}" CommandParameter="Continuous">
                            <materialDesign:PackIcon Kind="ViewSequential" />
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}" ToolTip="Facing"
                                      IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=Facing, Mode=OneWay}"
                                      Command="{Binding SetViewModeCommand}" CommandParameter="Facing">
                            <materialDesign:PackIcon Kind="BookOpenPageVariant" />
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}" ToolTip="Continuous Facing"
                                      IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=ContinuousFacing, Mode=OneWay}"
                                      Command="{Binding SetViewModeCommand}" CommandParameter="ContinuousFacing">
                            <materialDesign:PackIcon Kind="ViewGridOutline" />
                        </ToggleButton>
                        <ToggleButton Style="{StaticResource MaterialDesignFlatToggleButton}" ToolTip="Tách bìa (facing)"
                                      IsChecked="{Binding ShowCoverSeparately, Mode=TwoWay}">
                            <materialDesign:PackIcon Kind="BookOpenBlankVariant" />
                        </ToggleButton>

                        <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="16,0" />
                        
                        <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding PreviousPageCommand}" ToolTip="Previous Page">
                            <materialDesign:PackIcon Kind="ChevronLeft" />
                        </Button>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                            <TextBox x:Name="PageBox" Text="{Binding CurrentPage}" Width="30" TextAlignment="Center"
                                     materialDesign:TextFieldAssist.HasClearButton="False" KeyDown="PageBox_KeyDown"/>
                            <TextBlock Text="{Binding TotalPages, StringFormat='/ {0}'}" VerticalAlignment="Center" Margin="4,0"/>
                        </StackPanel>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding NextPageCommand}" ToolTip="Next Page">
                            <materialDesign:PackIcon Kind="ChevronRight" />
                        </Button>

                        <Separator Style="{StaticResource MaterialDesignLightSeparator}" Margin="16,0" />

                        <Button Style="{StaticResource MaterialDesignIconButton}" Command="{Binding ReindexDocumentCommand}" ToolTip="Lập chỉ mục lại">
                            <materialDesign:PackIcon Kind="DatabaseRefresh" />
                        </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Indexing status (blank when idle) -->
                    <TextBlock DockPanel.Dock="Left"
                               Text="{Binding IndexingStatusText}"
                               VerticalAlignment="Center" Margin="16,0"
                               Foreground="{DynamicResource PrimaryHueMidBrush}"
                               FontStyle="Italic" TextTrimming="CharacterEllipsis"/>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Visibility="{Binding IsReadingDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <materialDesign:ColorZone Mode="Standard" CornerRadius="20" materialDesign:ElevationAssist.Elevation="Dp0"
                                                  Background="{DynamicResource MaterialDesignTextFieldBoxBackground}" Padding="8,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Kind="Search" VerticalAlignment="Center" Margin="8,0" Opacity=".5" />
                                <TextBox x:Name="SearchBox" Grid.Column="1" Width="220"
                                         materialDesign:HintAssist.Hint="Search..." BorderThickness="0"
                                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="2" Style="{StaticResource MaterialDesignFlatButton}"
                                        Padding="4" MinWidth="0" VerticalAlignment="Center"
                                        ToolTip="Xóa tìm kiếm"
                                        Command="{Binding ClearSearchCommand}">
                                    <materialDesign:PackIcon Kind="Close" Opacity=".6" />
                                </Button>
                            </Grid>
                        </materialDesign:ColorZone>

                        <Popup IsOpen="{Binding SearchResults.Count, Converter={StaticResource CountToBoolConverter}, Mode=OneWay}"
                               PlacementTarget="{Binding ElementName=SearchBox}" Placement="Bottom"
                               StaysOpen="False" MaxHeight="420" Width="460">
                            <materialDesign:Card Padding="6" Background="{DynamicResource MaterialDesignPaper}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="408">
                                    <ItemsControl ItemsSource="{Binding SearchResults}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Border (not a Button): MaterialDesignFlatButton forces ~32px height and
                                                     its Ripple clips overflow, hiding the multi-line snippet. A Border sizes
                                                     to content; MouseBinding keeps click-to-navigate. -->
                                                <Border Background="Transparent" Padding="10,8" Cursor="Hand">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.SelectSearchResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding PageIndex, Converter={StaticResource PageDisplayConverter}, StringFormat='Trang {0}'}"
                                                                   FontWeight="Bold" FontSize="13"
                                                                   Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                        <TextBlock TextWrapping="Wrap" FontSize="14" Opacity="0.9" Margin="0,2,0,0"
                                                                   Foreground="{DynamicResource MaterialDesignBody}"
                                                                   local:SearchSnippetHighlighter.Text="{Binding Snippet}"
                                                                   local:SearchSnippetHighlighter.Query="{Binding DataContext.ExecutedSearchQuery, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </materialDesign:Card>
                        </Popup>
                    </StackPanel>
                </DockPanel>
            </materialDesign:ColorZone>

            <!-- PDF Viewer Surface -->
            <controls:PdfViewerControl Grid.Row="1" x:Name="PdfViewer"
                                       DocumentSource="{Binding FilePath}"
                                       CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                                       TotalPages="{Binding TotalPages, Mode=TwoWay}"
                                       ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                                       HighlightQuery="{Binding SelectedSearchQuery}"
                                       MatchSource="{Binding PdfService}"
                                       ViewMode="{Binding ViewMode}"
                                       ShowCover="{Binding ShowCoverSeparately}"
                                       AddNoteFromSelectionCommand="{Binding AddNoteFromSelectionCommand}"
                                       Highlights="{Binding Notes.Highlights}"
                                       CurrentDocumentId="{Binding CurrentDocumentId}"
                                       Visibility="{Binding ShowLibrary, Converter={StaticResource InverseBoolToVisibilityConverter}}" />

            <!-- Workspaces: lưới (ShowWorkspacesGrid) + chi tiết (ShowWorkspaceDetail) cùng vùng Grid -->

            <!-- Lưới workspace (chỉ hiện khi ShowWorkspacesGrid) -->
            <Border Grid.Row="1" Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding ShowWorkspacesGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <TextBlock Grid.Row="0" Text="Workspaces" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- Tạo workspace mới -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewWorkspaceNameBox"
                                 materialDesign:HintAssist.Hint="Tên workspace mới..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,8,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding CreateWorkspaceCommand}"
                                            CommandParameter="{Binding Text, ElementName=NewWorkspaceNameBox}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Content="Tạo workspace"
                                Command="{Binding CreateWorkspaceCommand}"
                                CommandParameter="{Binding Text, ElementName=NewWorkspaceNameBox}"
                                materialDesign:ButtonAssist.CornerRadius="20"/>
                    </Grid>
                        <TextBlock Text="{Binding WorkspaceNameError}" Foreground="#D32F2F"
                                   FontSize="12" Margin="2,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Danh sách workspace người dùng -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Chưa có workspace nào. Tạo workspace để nhóm tài liệu cùng chủ đề."
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Margin="0,32"
                                       Visibility="{Binding Workspaces.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                            <ItemsControl ItemsSource="{Binding Workspaces}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Width="200" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2"
                                                             Cursor="Hand">
                                            <Border Background="Transparent" Padding="12">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.OpenWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <StackPanel>
                                                    <materialDesign:PackIcon Kind="FolderMultipleOutline" Width="32" Height="32"
                                                                             HorizontalAlignment="Center" Margin="0,0,0,8"
                                                                             Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                               TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Chi tiết workspace (hiện khi ShowWorkspaceDetail) -->
            <Border Grid.Row="1" Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding ShowWorkspaceDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Hàng tiêu đề: nút Quay lại + tên workspace -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding BackToWorkspaceListCommand}"
                                ToolTip="Quay lại">
                            <materialDesign:PackIcon Kind="ArrowLeft" />
                        </Button>
                        <TextBlock Text="{Binding SelectedWorkspace.Name}" FontSize="20" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Tiêu đề danh sách tài liệu -->
                    <TextBlock Grid.Row="1" Text="Tài liệu trong workspace" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- Danh sách tài liệu trong workspace -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Chưa có tài liệu nào trong workspace. Thêm từ thư viện bên dưới."
                                       HorizontalAlignment="Center" Opacity="0.6" Margin="0,16"
                                       Visibility="{Binding WorkspaceDocuments.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                            <ItemsControl x:Name="WorkspaceDocsList" ItemsSource="{Binding WorkspaceDocuments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Title}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Content="Mở"
                                                        Command="{Binding DataContext.OpenWorkspaceDocumentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="4,0" Padding="8,4" MinWidth="0"/>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28"
                                                        ToolTip="Xoá khỏi workspace"
                                                        Command="{Binding DataContext.RemoveDocumentFromWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Tiêu đề khu thêm tài liệu -->
                    <TextBlock Grid.Row="3" Text="Thêm tài liệu từ thư viện" FontSize="13" FontWeight="SemiBold"
                               Margin="0,12,0,4"/>

                    <!-- Khu thêm tài liệu: ListBox đa chọn + nút Thêm vào workspace -->
                    <Grid Grid.Row="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="LibraryPickerBox" Grid.Row="0"
                                 SelectionMode="Extended"
                                 ItemsSource="{Binding Library}"
                                 DisplayMemberPath="Title"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        <Button Grid.Row="1"
                                Content="Thêm vào workspace"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                materialDesign:ButtonAssist.CornerRadius="20"
                                Command="{Binding AddDocumentsToWorkspaceCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=LibraryPickerBox}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Library grid (shown when ShowLibrary) -->
            <Border Grid.Row="1" Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding ShowLibrary, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <TextBlock Text="Chưa có tài liệu — bấm OPEN PDF để thêm vào thư viện."
                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"
                               Visibility="{Binding Library.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <ItemsControl ItemsSource="{Binding Library}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Width="180" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2">
                                        <Grid>
                                            <!-- Border (không phải MaterialDesignFlatButton: style đó ép ~32px + Ripple clip ảnh).
                                                 Border co theo nội dung; MouseBinding mở tài liệu khi bấm. -->
                                            <Border Background="Transparent" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.OpenLibraryItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <StackPanel>
                                                    <Image Source="{Binding ThumbPath, Converter={StaticResource PathToImageConverter}}" Height="220" Stretch="Uniform" Margin="0,8"/>
                                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" Margin="8,0" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding PageCount, StringFormat='{}{0} trang'}" Margin="8,0" Opacity="0.7" FontSize="11"/>
                                                    <TextBlock Text="{Binding LastOpenedAtUnix, Converter={StaticResource UnixToDateConverter}, StringFormat='Mở: {0}'}"
                                                               Margin="8,0,8,8" Opacity="0.6" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Nút xoá đè góc phải; bấm vào đây xoá, bấm chỗ khác mở tài liệu -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" ToolTip="Xoá khỏi thư viện"
                                                    Command="{Binding DataContext.RemoveLibraryItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Thanh kéo chỉnh bề rộng panel chat (ẩn cùng panel khi ở thư viện) -->
        <GridSplitter Grid.Column="2" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                      Background="{DynamicResource MaterialDesignDivider}"
                      Visibility="{Binding ShowLibrary, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

        <!-- Right Sidebar (AI + Notes) -->
        <materialDesign:Card Grid.Column="3" Margin="4" materialDesign:ElevationAssist.Elevation="Dp1" UniformCornerRadius="12"
                             Visibility="{Binding ShowLibrary, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <TabControl Style="{StaticResource MaterialDesignTabControl}"
                        materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                        SelectedIndex="{Binding Notes.RightTabIndex, Mode=TwoWay}">
                <TabItem Header="Chat">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Background="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                                            Padding="12" Margin="0,0,0,12"
                                                            UniformCornerRadius="8"
                                                            HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlignConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="10" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                <Button HorizontalAlignment="Right" Margin="0,2,0,0"
                                                        Width="28" Height="28" Padding="0"
                                                        ToolTip="Lưu thành ghi chú"
                                                        Command="{Binding DataContext.SaveAnswerAsNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Role}" Value="AI"/>
                                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=materialDesign:Card}}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <materialDesign:PackIcon Kind="NotePlusOutline" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Grid.Row="1" Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Ask a question..."
                                     Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="80">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                    Command="{Binding SendMessageCommand}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Bottom">
                                <materialDesign:PackIcon Kind="Send" />
                            </Button>
                        </Grid>

                        <materialDesign:Snackbar Grid.Row="0" Grid.RowSpan="2"
                                                 MessageQueue="{Binding NotesSnackbar}"
                                                 VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Notes">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Ô lọc -->
                        <TextBox Grid.Row="0" Margin="0,0,0,8"
                                 materialDesign:HintAssist.Hint="Lọc ghi chú"
                                 Text="{Binding Notes.FilterText, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Banner trích dẫn (hiện khi có PendingQuote từ chọn text) -->
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="3,0,0,0"
                                Padding="6,2" Margin="0,0,0,4"
                                Visibility="{Binding Notes.PendingQuote, Converter={StaticResource NullToCollapsedConverter}}">
                            <TextBlock Text="{Binding Notes.PendingQuote}" FontStyle="Italic" Opacity="0.8"
                                       TextTrimming="CharacterEllipsis" MaxHeight="48" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Ô soạn -->
                        <TextBox Grid.Row="2" MinHeight="60" Margin="0,0,0,4"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 IsEnabled="{Binding Notes.CanAddNote}"
                                 materialDesign:HintAssist.Hint="Viết ghi chú (Ctrl+Enter để lưu)"
                                 Text="{Binding Notes.Draft, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Modifiers="Control" Key="Enter" Command="{Binding Notes.SaveCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Hàng nút + thông báo -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Lưu" Command="{Binding Notes.SaveCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                            <Button Content="Hủy" Command="{Binding Notes.CancelEditCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Visibility="{Binding Notes.IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Notes.StatusMessage}" VerticalAlignment="Center"
                                       Margin="8,0,0,0" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
                        </StackPanel>

                        <!-- Danh sách note -->
                        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Notes.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,8" Padding="8" UniformCornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Chip nhãn tài liệu (chỉ hiện khi workspace có >1 tài liệu) -->
                                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                        Margin="0,0,0,4" HorizontalAlignment="Left"
                                                        Background="{Binding DocumentId, Converter={StaticResource DocumentIdToBrushConverter}}"
                                                        CornerRadius="10" Padding="6,2"
                                                        Visibility="{Binding DataContext.Notes.ShowDocumentChips, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="12" Height="12"
                                                                                 VerticalAlignment="Center" Margin="0,0,3,0"
                                                                                 Foreground="White"/>
                                                        <TextBlock FontSize="10" Foreground="White" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource DocumentIdToTitleConverter}">
                                                                    <Binding Path="DocumentId"/>
                                                                    <Binding Path="DataContext.Notes.DocumentTitles" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Khối trích dẫn (ẩn nếu null) -->
                                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                        BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="3,0,0,0"
                                                        Padding="6,0" Margin="0,0,0,4"
                                                        Visibility="{Binding Quote, Converter={StaticResource NullToCollapsedConverter}}">
                                                    <TextBlock Text="{Binding Quote}" FontStyle="Italic" Opacity="0.75"
                                                               TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                                </Border>

                                                <!-- Nội dung: click để nhảy trang -->
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Content}"
                                                           TextWrapping="Wrap" Cursor="Hand">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                            Command="{Binding DataContext.Notes.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    </TextBlock.InputBindings>
                                                </TextBlock>

                                                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28" ToolTip="Sửa"
                                                        Command="{Binding DataContext.Notes.BeginEditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                                </Button>
                                                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28" ToolTip="Xóa"
                                                        Command="{Binding DataContext.Notes.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>

                                                <!-- Badge trang (PageIndex 0-based -> hiển thị +1); ẩn nếu null -->
                                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                           Margin="0,4,0,0" FontSize="11" Opacity="0.7"
                                                           Text="{Binding PageIndex, Converter={StaticResource PageBadgeConverter}}"
                                                           Visibility="{Binding PageIndex, Converter={StaticResource NullToCollapsedConverter}}"/>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </materialDesign:Card>
    </Grid>
</Window>