<Window x:Class="PdfReaderApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:PdfReaderApp"
        xmlns:viewmodels="clr-namespace:PdfReaderApp.ViewModels"
        xmlns:controls="clr-namespace:PdfReaderApp.Controls"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}" Height="800" Width="1200"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        PreviewKeyDown="Window_PreviewKeyDown"
        FontFamily="{materialDesign:MaterialDesignFont}">
    <Window.Resources>
        <local:RoleToBrushConverter x:Key="RoleToBrushConverter" />
        <local:RoleToAlignConverter x:Key="RoleToAlignConverter" />
        <local:CountToBoolConverter x:Key="CountToBoolConverter" />
        <local:PageDisplayConverter x:Key="PageDisplayConverter" />
        <local:ViewModeToBoolConverter x:Key="ViewModeToBoolConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
        <local:CountToInverseVisibilityConverter x:Key="CountToInverseVisibilityConverter" />
        <local:UnixToDateConverter x:Key="UnixToDateConverter" />
        <local:PathToImageConverter x:Key="PathToImageConverter" />
        <local:PageBadgeConverter x:Key="PageBadgeConverter"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>
        <local:DocumentIdToBrushConverter x:Key="DocumentIdToBrushConverter"/>
        <local:DocumentIdToTitleConverter x:Key="DocumentIdToTitleConverter"/>
        <local:IsActiveTabConverter x:Key="IsActiveTabConverter"/>
        <local:NavDestinationToBoolConverter x:Key="NavDestinationToBoolConverter" />
    </Window.Resources>
    <Window.DataContext>
        <viewmodels:MainViewModel />
    </Window.DataContext>
    <Window.InputBindings>
        <KeyBinding Modifiers="Control" Key="OemPlus" Command="{Binding ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="Add" Command="{Binding ZoomInCommand}" />
        <KeyBinding Modifiers="Control" Key="OemMinus" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Modifiers="Control" Key="Subtract" Command="{Binding ZoomOutCommand}" />
        <KeyBinding Key="PageDown" Command="{Binding NextPageCommand}" />
        <KeyBinding Key="PageUp" Command="{Binding PreviousPageCommand}" />
        <KeyBinding Modifiers="Control" Key="Home" Command="{Binding FirstPageCommand}" />
        <KeyBinding Modifiers="Control" Key="End" Command="{Binding LastPageCommand}" />
        <KeyBinding Modifiers="Control" Key="O" Command="{Binding OpenFileCommand}" />
    </Window.InputBindings>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="{Binding ChatColumnWidth, Mode=TwoWay}"
                              MinWidth="{Binding ChatColumnMinWidth}" MaxWidth="700"/>
        </Grid.ColumnDefinitions>

        <!-- Navigation Rail (M3): nền surface, rộng 84, theo design -->
        <Border Grid.Column="0" Width="84" VerticalAlignment="Stretch"
                Background="{DynamicResource MaterialDesignPaper}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo: hộp bo tròn primary-container -->
                <Border Grid.Row="0" Width="56" Height="56" CornerRadius="18"
                        Background="{DynamicResource TriThu.Brush.PrimaryContainer}"
                        Effect="{DynamicResource TriThu.Elevation.E1}"
                        HorizontalAlignment="Center" Margin="0,14,0,14">
                    <!-- Logo "Trí Thư": hai nửa sách mở (một nửa mờ) + sparkle AI. SVG từ PDF Reader.dc.html. -->
                    <Viewbox Width="32" Height="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Canvas Width="32" Height="32">
                            <Path Fill="{DynamicResource TriThu.Brush.PrimaryContainer.On}"
                                  Data="M4 9C4 7.6 5.1 6.5 6.5 6.5H13C14.1 6.5 15 7.4 15 8.5V25C15 23.9 14.1 23 13 23H6.5C5.1 23 4 21.9 4 20.5V9Z"/>
                            <Path Fill="{DynamicResource TriThu.Brush.PrimaryContainer.On}" Opacity="0.45"
                                  Data="M28 9C28 7.6 26.9 6.5 25.5 6.5H19C17.9 6.5 17 7.4 17 8.5V25C17 23.9 17.9 23 19 23H25.5C26.9 23 28 21.9 28 20.5V9Z"/>
                            <Path Fill="{DynamicResource TriThu.Brush.PrimaryContainer.On}"
                                  Data="M24 2.5L24.85 4.9L27.25 5.75L24.85 6.6L24 9L23.15 6.6L20.75 5.75L23.15 4.9L24 2.5Z"/>
                        </Canvas>
                    </Viewbox>
                </Border>

                <StackPanel Grid.Row="1" VerticalAlignment="Top">
                    <!-- #38: quay lại tài liệu đang mở (chỉ bật khi có tài liệu) -->
                    <ToggleButton Style="{StaticResource TriThu.NavRailItem}" Tag="Tài liệu" ToolTip="Tài liệu đang mở"
                                  Command="{Binding ShowReaderViewCommand}"
                                  Visibility="{Binding HasDocument, Converter={StaticResource BooleanToVisibilityConverter}}"
                                  IsChecked="{Binding ActiveNavDestination, Converter={StaticResource NavDestinationToBoolConverter}, ConverterParameter=Reader, Mode=OneWay}">
                        <materialDesign:PackIcon Kind="FileDocument" Width="22" Height="22"/>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource TriThu.NavRailItem}" Tag="Thư viện" ToolTip="Thư viện"
                                  Command="{Binding ShowLibraryViewCommand}"
                                  IsChecked="{Binding ActiveNavDestination, Converter={StaticResource NavDestinationToBoolConverter}, ConverterParameter=Library, Mode=OneWay}">
                        <materialDesign:PackIcon Kind="BookOpenVariant" Width="22" Height="22"/>
                    </ToggleButton>
                    <ToggleButton Style="{StaticResource TriThu.NavRailItem}" Tag="Workspace" ToolTip="Workspaces"
                                  Command="{Binding ShowWorkspacesViewCommand}"
                                  IsChecked="{Binding ActiveNavDestination, Converter={StaticResource NavDestinationToBoolConverter}, ConverterParameter=Workspaces, Mode=OneWay}">
                        <materialDesign:PackIcon Kind="FolderMultipleOutline" Width="22" Height="22"/>
                    </ToggleButton>
                </StackPanel>

                <StackPanel Grid.Row="2" Margin="0,0,0,14">
                    <Button Style="{StaticResource TriThu.NavRailAction}" Tag="Cài đặt" ToolTip="Settings"
                            Command="{Binding OpenSettingsCommand}">
                        <materialDesign:PackIcon Kind="Settings" Width="22" Height="22"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Toolbar -->
            <Border Background="{DynamicResource MaterialDesignPaper}" Height="64" Padding="16,0">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                        <Button Style="{StaticResource TriThu.TopBar.FilledButton}" Command="{Binding OpenFileCommand}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- Icon upload-vào-khay, vẽ đúng SVG design (stroke) -->
                                <Viewbox Width="18" Height="18" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <Canvas Width="24" Height="24">
                                        <Path Stroke="{DynamicResource TriThu.Brush.OnPrimary}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Data="M12 15V5M8.5 8.5L12 5l3.5 3.5"/>
                                        <Path Stroke="{DynamicResource TriThu.Brush.OnPrimary}" StrokeThickness="2"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                                              Data="M5 16v1.5A2.5 2.5 0 0 0 7.5 20h9a2.5 2.5 0 0 0 2.5-2.5V16"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Mở PDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Nút điều khiển đọc: chỉ hiện khi đang đọc tài liệu (ẩn ở Thư viện/Workspaces) -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsReadingDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                            <Button Style="{StaticResource TriThu.TopBar.IconButton}" Command="{Binding ZoomOutCommand}" ToolTip="Thu nhỏ">
                                <materialDesign:PackIcon Kind="Minus" Width="20" Height="20"/>
                            </Button>
                            <Slider Style="{StaticResource TriThu.TopBar.ZoomSlider}" Minimum="0.4" Maximum="4.0"
                                    Value="{Binding ZoomLevel, Mode=TwoWay}" Margin="6,0" ToolTip="Zoom"/>
                            <Button Style="{StaticResource TriThu.TopBar.IconButton}" Command="{Binding ZoomInCommand}" ToolTip="Phóng to">
                                <materialDesign:PackIcon Kind="Plus" Width="20" Height="20"/>
                            </Button>
                            <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" VerticalAlignment="Center"
                                       Margin="6,0,0,0" MinWidth="42" TextAlignment="Center" FontSize="13" FontWeight="Medium"
                                       Foreground="{DynamicResource TriThu.Brush.OnSurfaceVariant}"/>
                        </StackPanel>
                        <Border Width="1" Height="26" Margin="10,0" VerticalAlignment="Center" Background="{DynamicResource TriThu.Brush.OutlineVariant}"/>

                        <!-- Segmented 4 view-mode: IsChecked OneWay (hiển thị) + Command đặt mode -->
                        <Border Height="38" CornerRadius="19" VerticalAlignment="Center" Margin="2,0,0,0"
                                BorderBrush="{DynamicResource TriThu.Brush.Outline}" BorderThickness="1">
                            <Grid>
                                <Border x:Name="SegMask" CornerRadius="18" Background="White"/>
                                <StackPanel Orientation="Horizontal">
                                    <StackPanel.OpacityMask>
                                        <VisualBrush Visual="{Binding ElementName=SegMask}"/>
                                    </StackPanel.OpacityMask>
                                    <ToggleButton Style="{StaticResource TriThu.TopBar.Segment}" ToolTip="Một trang"
                                                  IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=SinglePage, Mode=OneWay}"
                                                  Command="{Binding SetViewModeCommand}" CommandParameter="SinglePage">
                                        <materialDesign:PackIcon Kind="FileOutline" Width="20" Height="20"/>
                                    </ToggleButton>
                                    <Border Width="1" Background="{DynamicResource TriThu.Brush.Outline}"/>
                                    <ToggleButton Style="{StaticResource TriThu.TopBar.Segment}" ToolTip="Cuộn liên tục"
                                                  IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=Continuous, Mode=OneWay}"
                                                  Command="{Binding SetViewModeCommand}" CommandParameter="Continuous">
                                        <materialDesign:PackIcon Kind="ViewSequential" Width="20" Height="20"/>
                                    </ToggleButton>
                                    <Border Width="1" Background="{DynamicResource TriThu.Brush.Outline}"/>
                                    <ToggleButton Style="{StaticResource TriThu.TopBar.Segment}" ToolTip="Hai trang"
                                                  IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=Facing, Mode=OneWay}"
                                                  Command="{Binding SetViewModeCommand}" CommandParameter="Facing">
                                        <materialDesign:PackIcon Kind="BookOpenPageVariant" Width="20" Height="20"/>
                                    </ToggleButton>
                                    <Border Width="1" Background="{DynamicResource TriThu.Brush.Outline}"/>
                                    <ToggleButton Style="{StaticResource TriThu.TopBar.Segment}" ToolTip="Hai trang cuộn"
                                                  IsChecked="{Binding ViewMode, Converter={StaticResource ViewModeToBoolConverter}, ConverterParameter=ContinuousFacing, Mode=OneWay}"
                                                  Command="{Binding SetViewModeCommand}" CommandParameter="ContinuousFacing">
                                        <materialDesign:PackIcon Kind="ViewGridOutline" Width="20" Height="20"/>
                                    </ToggleButton>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <ToggleButton Style="{StaticResource TriThu.TopBar.OutlineToggle}" Margin="8,0,0,0"
                                      ToolTip="Trang bìa đứng riêng / ghép đôi"
                                      IsChecked="{Binding ShowCoverSeparately, Mode=TwoWay}">
                            <materialDesign:PackIcon Kind="BookOpenBlankVariant" Width="20" Height="20"/>
                        </ToggleButton>

                        <Button Style="{StaticResource TriThu.TopBar.IconButton}" Command="{Binding ReindexDocumentCommand}" ToolTip="Lập chỉ mục lại" Margin="6,0,0,0">
                            <materialDesign:PackIcon Kind="DatabaseRefresh" Width="20" Height="20"/>
                        </Button>
                        </StackPanel>
                    </StackPanel>

                    <!-- Indexing status (blank when idle) -->
                    <TextBlock DockPanel.Dock="Left" Text="{Binding IndexingStatusText}"
                               VerticalAlignment="Center" Margin="16,0"
                               Foreground="{DynamicResource TriThu.Brush.OnSurfaceVariant}"
                               FontStyle="Italic" TextTrimming="CharacterEllipsis"/>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Width="300" Margin="8,0,0,0"
                                Visibility="{Binding IsReadingDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border x:Name="SearchBar" Height="44" CornerRadius="22" Padding="16,0,6,0" Width="300"
                                Background="{DynamicResource TriThu.Brush.SurfaceTonalHigh}" BorderThickness="2" BorderBrush="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource TriThu.Brush.SurfaceTonalLowest}"/>
                                            <Setter Property="BorderBrush" Value="{DynamicResource TriThu.Brush.Primary}"/>
                                            <Setter Property="Effect" Value="{DynamicResource TriThu.Elevation.E2}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <materialDesign:PackIcon Grid.Column="0" Kind="Magnify" Width="20" Height="20" VerticalAlignment="Center"
                                                         Margin="0,0,10,0" Foreground="{DynamicResource TriThu.Brush.OnSurfaceVariant}"/>
                                <TextBox x:Name="SearchBox" Grid.Column="1" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                         BorderThickness="0" Background="Transparent" FontSize="14"
                                         Foreground="{DynamicResource MaterialDesignBody}"
                                         materialDesign:HintAssist.Hint="Tìm trong tài liệu"
                                         materialDesign:TextFieldAssist.DecorationVisibility="Collapsed"
                                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding SearchCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Button Grid.Column="2" Style="{StaticResource TriThu.TopBar.IconButton}" Width="30" Height="30"
                                        ToolTip="Xoá tìm kiếm" Command="{Binding ClearSearchCommand}">
                                    <materialDesign:PackIcon Kind="Close" Width="16" Height="16"/>
                                </Button>
                            </Grid>
                        </Border>

                        <Popup IsOpen="{Binding SearchResults.Count, Converter={StaticResource CountToBoolConverter}, Mode=OneWay}"
                               PlacementTarget="{Binding ElementName=SearchBox}" Placement="Bottom"
                               StaysOpen="False" MaxHeight="430" Width="380" VerticalOffset="8">
                            <Border Background="{DynamicResource TriThu.Brush.SurfaceTonalLowest}"
                                    BorderBrush="{DynamicResource TriThu.Brush.OutlineVariant}" BorderThickness="1"
                                    CornerRadius="16" Effect="{DynamicResource TriThu.Elevation.E3}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Margin="16,13,16,11" FontSize="12" FontWeight="Medium"
                                               Foreground="{DynamicResource TriThu.Brush.OnSurfaceVariant}">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} kết quả cho &quot;{1}&quot;">
                                                <Binding Path="SearchResults.Count"/>
                                                <Binding Path="ExecutedSearchQuery"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                    <Border Grid.Row="0" Height="1" VerticalAlignment="Bottom"
                                            Background="{DynamicResource TriThu.Brush.OutlineVariant}"/>
                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="380" Padding="6">
                                        <ItemsControl ItemsSource="{Binding SearchResults}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="Transparent" Padding="12,11" CornerRadius="10" Cursor="Hand">
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.SelectSearchResultCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding PageIndex, Converter={StaticResource PageDisplayConverter}, StringFormat='Trang {0}'}"
                                                                       FontFamily="{DynamicResource TriThu.Font.Mono}" FontSize="11" FontWeight="Medium"
                                                                       Foreground="{DynamicResource TriThu.Brush.Primary}"/>
                                                            <TextBlock TextWrapping="Wrap" FontSize="14" Margin="0,4,0,0"
                                                                       Foreground="{DynamicResource MaterialDesignBody}"
                                                                       local:SearchSnippetHighlighter.Text="{Binding Snippet}"
                                                                       local:SearchSnippetHighlighter.Query="{Binding DataContext.ExecutedSearchQuery, RelativeSource={RelativeSource AncestorType=ItemsControl}}"/>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </Popup>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Tab Strip (Row 1): chỉ hiện trong workspace session -->
            <Border Grid.Row="1"
                    Visibility="{Binding IsWorkspaceSession, Converter={StaticResource BooleanToVisibilityConverter}}"
                    BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1"
                    Background="{DynamicResource MaterialDesignPaper}">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding Tabs.Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border MinWidth="120" MaxWidth="200" Padding="0"
                                        ToolTip="{Binding Title}"
                                        Cursor="Hand">
                                    <!-- Highlight tab đang active bằng bottom border PrimaryMid -->
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="BorderThickness" Value="0,0,0,3"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                            <Style.Triggers>
                                                <DataTrigger Value="Visible">
                                                    <DataTrigger.Binding>
                                                        <MultiBinding Converter="{StaticResource IsActiveTabConverter}">
                                                            <Binding/>
                                                            <Binding Path="DataContext.Tabs.ActiveTab" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                        </MultiBinding>
                                                    </DataTrigger.Binding>
                                                    <Setter Property="BorderBrush" Value="{DynamicResource TriThu.Brush.Primary}"/>
                                                    <Setter Property="Background" Value="{DynamicResource MaterialDesignTextFieldBoxBackground}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Border.InputBindings>
                                        <MouseBinding MouseAction="LeftClick"
                                                      Command="{Binding DataContext.ActivateTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                        <MouseBinding MouseAction="MiddleClick"
                                                      Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                      CommandParameter="{Binding}"/>
                                    </Border.InputBindings>
                                    <Grid Margin="12,6,4,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <Button Grid.Column="1"
                                                Style="{StaticResource MaterialDesignIconButton}"
                                                Width="22" Height="22" Padding="0"
                                                ToolTip="Đóng tab"
                                                Command="{Binding DataContext.CloseTabCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                VerticalAlignment="Center">
                                            <materialDesign:PackIcon Kind="Close" Width="14" Height="14"/>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- PDF Viewer Surface — standalone (IsWorkspaceSession=false).
                 Hiện khi: không phải workspace session VÀ không đang ở thư viện. -->
            <controls:PdfViewerControl Grid.Row="2" x:Name="PdfViewer"
                                       DocumentSource="{Binding StandaloneDocumentSource}"
                                       CurrentPage="{Binding CurrentPage, Mode=TwoWay}"
                                       TotalPages="{Binding TotalPages, Mode=TwoWay}"
                                       ZoomLevel="{Binding ZoomLevel, Mode=TwoWay}"
                                       HighlightQuery="{Binding SelectedSearchQuery}"
                                       MatchSource="{Binding PdfService}"
                                       ViewMode="{Binding ViewMode}"
                                       ShowCover="{Binding ShowCoverSeparately}"
                                       AddNoteFromSelectionCommand="{Binding AddNoteFromSelectionCommand}"
                                       Highlights="{Binding Notes.Highlights}"
                                       CurrentDocumentId="{Binding CurrentDocumentId}">
                <controls:PdfViewerControl.Style>
                    <Style TargetType="controls:PdfViewerControl">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ShowLibrary}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsWorkspaceSession}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </controls:PdfViewerControl.Style>
            </controls:PdfViewerControl>

            <!-- Viewer-per-tab host (IsWorkspaceSession=true): một PdfViewerControl cho mỗi tab,
                 chỉ tab active Visible, còn lại Collapsed (không render). -->
            <Border Grid.Row="2"
                    Visibility="{Binding IsWorkspaceSession, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <!-- Placeholder khi chưa có tab nào (HasTabs=false) -->
                    <TextBlock Text="Mở một tài liệu trong workspace"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Opacity="0.5" FontSize="16"
                               Visibility="{Binding Tabs.HasTabs, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

                    <!-- Một PdfViewerControl trên mỗi tab, xếp chồng, chỉ active visible -->
                    <ItemsControl ItemsSource="{Binding Tabs.Tabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Grid/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <controls:PdfViewerControl
                                    DocumentSource="{Binding Path}"
                                    CurrentPage="{Binding Page, Mode=TwoWay}"
                                    TotalPages="{Binding TotalPages, Mode=OneWayToSource}"
                                    ZoomLevel="{Binding Zoom, Mode=TwoWay}"
                                    CurrentDocumentId="{Binding DocumentId}"
                                    HighlightQuery="{Binding DataContext.SelectedSearchQuery, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    MatchSource="{Binding DataContext.PdfService, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    ViewMode="{Binding DataContext.ViewMode, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    ShowCover="{Binding DataContext.ShowCoverSeparately, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    AddNoteFromSelectionCommand="{Binding DataContext.AddNoteFromSelectionCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    Highlights="{Binding DataContext.Notes.Highlights, RelativeSource={RelativeSource AncestorType=ItemsControl}}">
                                    <controls:PdfViewerControl.Visibility>
                                        <MultiBinding Converter="{StaticResource IsActiveTabConverter}">
                                            <Binding/>
                                            <Binding Path="DataContext.Tabs.ActiveTab" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                        </MultiBinding>
                                    </controls:PdfViewerControl.Visibility>
                                </controls:PdfViewerControl>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- Workspaces: lưới (ShowWorkspacesGrid) + chi tiết (ShowWorkspaceDetail) cùng vùng Grid -->

            <!-- Lưới workspace (chỉ hiện khi ShowWorkspacesGrid) -->
            <Border Grid.Row="2" Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding ShowWorkspacesGrid, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Tiêu đề -->
                    <TextBlock Grid.Row="0" Text="Workspaces" FontSize="20" FontWeight="Bold" Margin="0,0,0,12"/>

                    <!-- Tạo workspace mới -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="NewWorkspaceNameBox"
                                 materialDesign:HintAssist.Hint="Tên workspace mới..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                 Margin="0,0,8,0">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Enter"
                                            Command="{Binding CreateWorkspaceCommand}"
                                            CommandParameter="{Binding Text, ElementName=NewWorkspaceNameBox}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Grid.Column="1"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Content="Tạo workspace"
                                Command="{Binding CreateWorkspaceCommand}"
                                CommandParameter="{Binding Text, ElementName=NewWorkspaceNameBox}"
                                materialDesign:ButtonAssist.CornerRadius="20"/>
                    </Grid>
                        <TextBlock Text="{Binding WorkspaceNameError}" Foreground="#D32F2F"
                                   FontSize="12" Margin="2,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Danh sách workspace người dùng -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Chưa có workspace nào. Tạo workspace để nhóm tài liệu cùng chủ đề."
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6" Margin="0,32"
                                       Visibility="{Binding Workspaces.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                            <ItemsControl ItemsSource="{Binding Workspaces}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Width="200" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2"
                                                             Cursor="Hand">
                                            <Grid>
                                                <Border Background="Transparent" Padding="12">
                                                    <Border.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                                      Command="{Binding DataContext.OpenWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                      CommandParameter="{Binding}"/>
                                                    </Border.InputBindings>
                                                    <StackPanel>
                                                        <materialDesign:PackIcon Kind="FolderMultipleOutline" Width="32" Height="32"
                                                                                 HorizontalAlignment="Center" Margin="0,0,0,8"
                                                                                 Foreground="{DynamicResource TriThu.Brush.Primary}"/>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                                   TextTrimming="CharacterEllipsis" TextAlignment="Center"/>
                                                    </StackPanel>
                                                </Border>
                                                <!-- Nút xóa workspace -->
                                                <Button Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Margin="0,4,4,0"
                                                        ToolTip="Xóa workspace"
                                                        Command="{Binding DataContext.DeleteWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Chi tiết workspace (hiện khi ShowWorkspaceDetail) -->
            <Border Grid.Row="2" Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding ShowWorkspaceDetail, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="200"/>
                    </Grid.RowDefinitions>

                    <!-- Hàng tiêu đề: nút Quay lại + tên workspace -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource MaterialDesignIconButton}"
                                Command="{Binding BackToWorkspaceListCommand}"
                                ToolTip="Quay lại">
                            <materialDesign:PackIcon Kind="ArrowLeft" />
                        </Button>
                        <TextBlock Text="{Binding SelectedWorkspace.Name}" FontSize="20" FontWeight="Bold"
                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                    </StackPanel>

                    <!-- Hàng đổi tên workspace -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="RenameWorkspaceBox"
                                     materialDesign:HintAssist.Hint="Tên mới..."
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Text="{Binding RenameDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Content="Đổi tên"
                                    Command="{Binding RenameWorkspaceCommand}"
                                    CommandParameter="{Binding Text, ElementName=RenameWorkspaceBox}"
                                    materialDesign:ButtonAssist.CornerRadius="20"/>
                        </Grid>
                        <TextBlock Text="{Binding WorkspaceNameError}" Foreground="#D32F2F"
                                   FontSize="12" Margin="2,4,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- Tiêu đề danh sách tài liệu -->
                    <TextBlock Grid.Row="2" Text="Tài liệu trong workspace" FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <!-- Danh sách tài liệu trong workspace -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Chưa có tài liệu nào trong workspace. Thêm từ thư viện bên dưới."
                                       HorizontalAlignment="Center" Opacity="0.6" Margin="0,16"
                                       Visibility="{Binding WorkspaceDocuments.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                            <ItemsControl x:Name="WorkspaceDocsList" ItemsSource="{Binding WorkspaceDocuments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="8,4" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="{Binding Title}" VerticalAlignment="Center"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource MaterialDesignFlatButton}"
                                                        Content="Mở"
                                                        Command="{Binding DataContext.OpenWorkspaceDocumentCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Margin="4,0" Padding="8,4" MinWidth="0"/>
                                                <Button Grid.Column="2"
                                                        Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28"
                                                        ToolTip="Xoá khỏi workspace"
                                                        Command="{Binding DataContext.RemoveDocumentFromWorkspaceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- Tiêu đề khu thêm tài liệu -->
                    <TextBlock Grid.Row="4" Text="Thêm tài liệu từ thư viện" FontSize="13" FontWeight="SemiBold"
                               Margin="0,12,0,4"/>

                    <!-- Khu thêm tài liệu: ListBox đa chọn + nút Thêm vào workspace -->
                    <Grid Grid.Row="5">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListBox x:Name="LibraryPickerBox" Grid.Row="0"
                                 SelectionMode="Extended"
                                 ItemsSource="{Binding Library}"
                                 DisplayMemberPath="Title"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        <Button Grid.Row="1"
                                Content="Thêm vào workspace"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                HorizontalAlignment="Left"
                                Margin="0,8,0,0"
                                materialDesign:ButtonAssist.CornerRadius="20"
                                Command="{Binding AddDocumentsToWorkspaceCommand}"
                                CommandParameter="{Binding SelectedItems, ElementName=LibraryPickerBox}"/>
                    </Grid>
                </Grid>
            </Border>

            <!-- Library grid (shown when ShowLibrary) -->
            <Border Grid.Row="2" Background="{DynamicResource MaterialDesignPaper}"
                    Visibility="{Binding ShowLibrary, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <TextBlock Text="Chưa có tài liệu — bấm OPEN PDF để thêm vào thư viện."
                               HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"
                               Visibility="{Binding Library.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                        <ItemsControl ItemsSource="{Binding Library}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <materialDesign:Card Width="180" Margin="8" materialDesign:ElevationAssist.Elevation="Dp2">
                                        <Grid>
                                            <!-- Border (không phải MaterialDesignFlatButton: style đó ép ~32px + Ripple clip ảnh).
                                                 Border co theo nội dung; MouseBinding mở tài liệu khi bấm. -->
                                            <Border Background="Transparent" Cursor="Hand">
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.OpenLibraryItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                <StackPanel>
                                                    <Image Source="{Binding ThumbPath, Converter={StaticResource PathToImageConverter}}" Height="220" Stretch="Uniform" Margin="0,8"/>
                                                    <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" Margin="8,0" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding PageCount, StringFormat='{}{0} trang'}" Margin="8,0" Opacity="0.7" FontSize="11"/>
                                                    <TextBlock Text="{Binding LastOpenedAtUnix, Converter={StaticResource UnixToDateConverter}, StringFormat='Mở: {0}'}"
                                                               Margin="8,0,8,8" Opacity="0.6" FontSize="10"/>
                                                </StackPanel>
                                            </Border>
                                            <!-- Nút xoá đè góc phải; bấm vào đây xoá, bấm chỗ khác mở tài liệu -->
                                            <Button Style="{StaticResource MaterialDesignIconButton}" Width="30" Height="30"
                                                    HorizontalAlignment="Right" VerticalAlignment="Top" ToolTip="Xoá khỏi thư viện"
                                                    Command="{Binding DataContext.RemoveLibraryItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
                                            </Button>
                                        </Grid>
                                    </materialDesign:Card>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

                <!-- Floating page pill: điều hướng trang, nổi đáy-giữa vùng viewer (design) -->
                <Border Grid.Row="2" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,22"
                        Height="44" Padding="5" CornerRadius="22" Panel.ZIndex="15"
                        Background="{DynamicResource TriThu.Brush.InverseSurface}"
                        Effect="{DynamicResource TriThu.Elevation.E3}"
                        Visibility="{Binding IsReadingDocument, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Style="{StaticResource TriThu.PagePill.Button}" Command="{Binding PreviousPageCommand}" ToolTip="Trang trước">
                            <materialDesign:PackIcon Kind="ChevronLeft" Width="18" Height="18"/>
                        </Button>
                        <TextBlock VerticalAlignment="Center" Margin="8,0" FontSize="13" FontWeight="Medium"
                                   Foreground="{DynamicResource TriThu.Brush.InverseSurface.On}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} / {1}">
                                    <Binding Path="CurrentPage"/>
                                    <Binding Path="TotalPages"/>
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                        <Button Style="{StaticResource TriThu.PagePill.Button}" Command="{Binding NextPageCommand}" ToolTip="Trang sau">
                            <materialDesign:PackIcon Kind="ChevronRight" Width="18" Height="18"/>
                        </Button>
                    </StackPanel>
                </Border>
        </Grid>

        <!-- Thanh kéo chỉnh bề rộng panel chat (ẩn cùng panel khi ở thư viện) -->
        <GridSplitter Grid.Column="2" Width="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                      Background="{DynamicResource MaterialDesignDivider}"
                      Visibility="{Binding ShowLibrary, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>

        <!-- Right Sidebar (AI + Notes) -->
        <materialDesign:Card Grid.Column="3" Margin="4" materialDesign:ElevationAssist.Elevation="Dp1" UniformCornerRadius="12"
                             Visibility="{Binding ShowLibrary, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <TabControl Style="{StaticResource MaterialDesignTabControl}"
                        materialDesign:ColorZoneAssist.Mode="PrimaryMid"
                        SelectedIndex="{Binding Notes.RightTabIndex, Mode=TwoWay}">
                <TabItem Header="Chat">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ChatMessages}" Margin="16">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Background="{Binding Role, Converter={StaticResource RoleToBrushConverter}}"
                                                            Padding="12" Margin="0,0,0,12"
                                                            UniformCornerRadius="8"
                                                            HorizontalAlignment="{Binding Role, Converter={StaticResource RoleToAlignConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Role}" FontWeight="Bold" FontSize="10" Opacity="0.7"/>
                                                <TextBlock Text="{Binding Content}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                <Button HorizontalAlignment="Right" Margin="0,2,0,0"
                                                        Width="28" Height="28" Padding="0"
                                                        ToolTip="Lưu thành ghi chú"
                                                        Command="{Binding DataContext.SaveAnswerAsNoteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource MaterialDesignIconButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding Role}" Value="AI"/>
                                                                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=materialDesign:Card}}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <materialDesign:PackIcon Kind="NotePlusOutline" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <Grid Grid.Row="1" Margin="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     materialDesign:HintAssist.Hint="Ask a question..."
                                     Text="{Binding ChatInput, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     Height="80">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding SendMessageCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Button Grid.Column="1"
                                    Style="{StaticResource MaterialDesignFloatingActionMiniButton}"
                                    Command="{Binding SendMessageCommand}"
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Bottom">
                                <materialDesign:PackIcon Kind="Send" />
                            </Button>
                        </Grid>

                        <materialDesign:Snackbar Grid.Row="0" Grid.RowSpan="2"
                                                 MessageQueue="{Binding NotesSnackbar}"
                                                 VerticalAlignment="Bottom" HorizontalAlignment="Stretch"/>
                    </Grid>
                </TabItem>
                <TabItem Header="Notes">
                    <Grid Margin="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Ô lọc -->
                        <TextBox Grid.Row="0" Margin="0,0,0,8"
                                 materialDesign:HintAssist.Hint="Lọc ghi chú"
                                 Text="{Binding Notes.FilterText, UpdateSourceTrigger=PropertyChanged}"/>

                        <!-- Banner trích dẫn (hiện khi có PendingQuote từ chọn text) -->
                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="3,0,0,0"
                                Padding="6,2" Margin="0,0,0,4"
                                Visibility="{Binding Notes.PendingQuote, Converter={StaticResource NullToCollapsedConverter}}">
                            <TextBlock Text="{Binding Notes.PendingQuote}" FontStyle="Italic" Opacity="0.8"
                                       TextTrimming="CharacterEllipsis" MaxHeight="48" TextWrapping="Wrap"/>
                        </Border>

                        <!-- Ô soạn -->
                        <TextBox Grid.Row="2" MinHeight="60" Margin="0,0,0,4"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 IsEnabled="{Binding Notes.CanAddNote}"
                                 materialDesign:HintAssist.Hint="Viết ghi chú (Ctrl+Enter để lưu)"
                                 Text="{Binding Notes.Draft, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Modifiers="Control" Key="Enter" Command="{Binding Notes.SaveCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>

                        <!-- Hàng nút + thông báo -->
                        <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="Lưu" Command="{Binding Notes.SaveCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                            <Button Content="Hủy" Command="{Binding Notes.CancelEditCommand}"
                                    Style="{StaticResource MaterialDesignFlatButton}"
                                    Visibility="{Binding Notes.IsEditing, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            <TextBlock Text="{Binding Notes.StatusMessage}" VerticalAlignment="Center"
                                       Margin="8,0,0,0" Foreground="{DynamicResource TriThu.Brush.Primary}"/>
                        </StackPanel>

                        <!-- Danh sách note -->
                        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding Notes.Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <materialDesign:Card Margin="0,0,0,8" Padding="8" UniformCornerRadius="8">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Chip nhãn tài liệu (chỉ hiện khi workspace có >1 tài liệu) -->
                                                <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                                                        Margin="0,0,0,4" HorizontalAlignment="Left"
                                                        Background="{Binding DocumentId, Converter={StaticResource DocumentIdToBrushConverter}}"
                                                        CornerRadius="10" Padding="6,2"
                                                        Visibility="{Binding DataContext.Notes.ShowDocumentChips, RelativeSource={RelativeSource AncestorType=ItemsControl}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="FileDocumentOutline" Width="12" Height="12"
                                                                                 VerticalAlignment="Center" Margin="0,0,3,0"
                                                                                 Foreground="White"/>
                                                        <TextBlock FontSize="10" Foreground="White" VerticalAlignment="Center">
                                                            <TextBlock.Text>
                                                                <MultiBinding Converter="{StaticResource DocumentIdToTitleConverter}">
                                                                    <Binding Path="DocumentId"/>
                                                                    <Binding Path="DataContext.Notes.DocumentTitles" RelativeSource="{RelativeSource AncestorType=ItemsControl}"/>
                                                                </MultiBinding>
                                                            </TextBlock.Text>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Khối trích dẫn (ẩn nếu null) -->
                                                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                                        BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="3,0,0,0"
                                                        Padding="6,0" Margin="0,0,0,4"
                                                        Visibility="{Binding Quote, Converter={StaticResource NullToCollapsedConverter}}">
                                                    <TextBlock Text="{Binding Quote}" FontStyle="Italic" Opacity="0.75"
                                                               TextWrapping="Wrap" MaxHeight="60" TextTrimming="CharacterEllipsis"/>
                                                </Border>

                                                <!-- Nội dung: click để nhảy trang -->
                                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Content}"
                                                           TextWrapping="Wrap" Cursor="Hand">
                                                    <TextBlock.InputBindings>
                                                        <MouseBinding MouseAction="LeftClick"
                                                            Command="{Binding DataContext.Notes.OpenCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                            CommandParameter="{Binding}"/>
                                                    </TextBlock.InputBindings>
                                                </TextBlock>

                                                <Button Grid.Row="2" Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28" ToolTip="Sửa"
                                                        Command="{Binding DataContext.Notes.BeginEditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Pencil" Width="16" Height="16"/>
                                                </Button>
                                                <Button Grid.Row="2" Grid.Column="2" Style="{StaticResource MaterialDesignIconButton}"
                                                        Width="28" Height="28" ToolTip="Xóa"
                                                        Command="{Binding DataContext.Notes.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <materialDesign:PackIcon Kind="Delete" Width="16" Height="16"/>
                                                </Button>

                                                <!-- Badge trang (PageIndex 0-based -> hiển thị +1); ẩn nếu null -->
                                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                                                           Margin="0,4,0,0" FontSize="11" Opacity="0.7"
                                                           Text="{Binding PageIndex, Converter={StaticResource PageBadgeConverter}}"
                                                           Visibility="{Binding PageIndex, Converter={StaticResource NullToCollapsedConverter}}"/>
                                            </Grid>
                                        </materialDesign:Card>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </materialDesign:Card>
    </Grid>
</Window>