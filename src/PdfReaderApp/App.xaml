<Application x:Class="PdfReaderApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:PdfReaderApp"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:CustomColorTheme BaseTheme="Light" PrimaryColor="#006B5B" SecondaryColor="#4A635C" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PdfReaderApp;component/Themes/TriThuTokens.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PdfReaderApp;component/Themes/NavRail.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PdfReaderApp;component/Themes/ReaderTopBar.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PdfReaderApp;component/Themes/DocTabStrip.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PdfReaderApp;component/Themes/RightPanel.xaml" />
                <ResourceDictionary Source="pack://application:,,,/PdfReaderApp;component/Themes/LibraryCard.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>