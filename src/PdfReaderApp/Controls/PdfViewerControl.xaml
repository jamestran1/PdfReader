<UserControl x:Class="PdfReaderApp.Controls.PdfViewerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
             xmlns:local="clr-namespace:PdfReaderApp.Controls"
             mc:Ignorable="d" d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#525659">
        <!-- GPU Render Layer (Fixed to Viewport) -->
        <skia:SKElement x:Name="skiaCanvas" 
                        PaintSurface="OnPaintCanvas" 
                        Margin="10" />
        
        <!-- Virtualized Scroll Area -->
        <ScrollViewer x:Name="PagesScrollViewer" 
                      CanContentScroll="True" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Auto"
                      ScrollChanged="PagesScrollViewer_ScrollChanged">
            <Grid>
                <!-- Interaction / Editing Overlay -->
                <Canvas x:Name="InteractionCanvas" Margin="10" Background="Transparent">
                    <local:MicroEditor x:Name="TextEditor" Visibility="Collapsed" />
                    <Button x:Name="AddNoteButton" Visibility="Collapsed" Panel.ZIndex="100"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Content="Thêm ghi chú" Padding="8,2" FontSize="12"
                            Click="AddNoteButton_Click"/>
                </Canvas>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>