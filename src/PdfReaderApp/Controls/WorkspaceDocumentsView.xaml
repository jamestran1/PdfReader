<UserControl x:Class="PdfReaderApp.Controls.WorkspaceDocumentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:converters="clr-namespace:PdfReaderApp.Converters"
             xmlns:local="clr-namespace:PdfReaderApp">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <local:CountToInverseVisibilityConverter x:Key="CountToInverseVisibilityConverter"/>
        <converters:LibraryCoverBrushConverter x:Key="LibraryCoverBrushConverter"/>
        <local:NullToCollapsedConverter x:Key="NullToCollapsedConverter"/>

        <Style x:Key="ZoneHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource TriThu.Brush.OnSurfaceVariant}"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
        <Style x:Key="ZoneEmptyNote" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12.5"/>
            <Setter Property="Foreground" Value="{DynamicResource TriThu.Brush.OnSurfaceVariant}"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>
    </UserControl.Resources>

    <Border Background="{DynamicResource TriThu.Brush.SurfaceTonalLowest}" CornerRadius="16"
            BorderBrush="{DynamicResource TriThu.Brush.OutlineVariant}" BorderThickness="1">
        <DockPanel Margin="18">
            <!-- Header: tiêu đề + tên Workspace (đổi tên inline) + nút đóng (chỉ hiện ở host modal) -->
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Tài liệu Workspace" FontSize="16" FontWeight="Bold"
                               Foreground="{DynamicResource TriThu.Brush.OnSurface}"/>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRenaming, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <TextBlock Text="{Binding WorkspaceName}" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{DynamicResource TriThu.Brush.OnSurfaceVariant}"/>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                ToolTip="Đổi tên Workspace" Command="{Binding BeginRenameCommand}">
                            <materialDesign:PackIcon Kind="PencilOutline" Width="14" Height="14"/>
                        </Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                Visibility="{Binding IsRenaming, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <TextBox MinWidth="220" materialDesign:HintAssist.Hint="Tên Workspace"
                                 Text="{Binding RenameDraft, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding CommitRenameCommand}"/>
                                <KeyBinding Key="Escape" Command="{Binding CancelRenameCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                ToolTip="Lưu tên" Command="{Binding CommitRenameCommand}">
                            <materialDesign:PackIcon Kind="Check" Width="15" Height="15"/>
                        </Button>
                        <Button Style="{StaticResource MaterialDesignIconButton}" Width="28" Height="28"
                                ToolTip="Hủy" Command="{Binding CancelRenameCommand}">
                            <materialDesign:PackIcon Kind="Close" Width="15" Height="15"/>
                        </Button>
                    </StackPanel>
                    <TextBlock Text="{Binding RenameError}" FontSize="11"
                               Foreground="{DynamicResource TriThu.Brush.Error}"
                               Visibility="{Binding RenameError, Converter={StaticResource NullToCollapsedConverter}}"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource MaterialDesignIconButton}"
                        ToolTip="Đóng" Command="{Binding CloseModalCommand}"
                        Visibility="{Binding IsModalOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <materialDesign:PackIcon Kind="Close"/>
                </Button>
            </Grid>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Vùng 1: tài liệu thành viên -->
                    <TextBlock Style="{StaticResource ZoneHeader}" Text="Trong Workspace"/>
                    <TextBlock Style="{StaticResource ZoneEmptyNote}"
                               Text="Workspace chưa có tài liệu. Thêm từ thư viện bên dưới."
                               Visibility="{Binding Members.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding Members}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="132" Margin="0,0,14,16">
                                    <Border Style="{StaticResource TriThu.LibraryCard}" Height="170" Cursor="Hand"
                                            Background="{Binding Converter={StaticResource LibraryCoverBrushConverter}}">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick"
                                                          Command="{Binding DataContext.OpenMemberCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                          CommandParameter="{Binding}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="Bold"
                                                       TextWrapping="Wrap" Margin="10" VerticalAlignment="Bottom"/>
                                            <Button Style="{StaticResource TriThu.LibraryCard.Delete}"
                                                    HorizontalAlignment="Left" VerticalAlignment="Top" Margin="8"
                                                    ToolTip="Gỡ khỏi Workspace"
                                                    Command="{Binding DataContext.RemoveMemberCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <materialDesign:PackIcon Kind="Delete" Width="14" Height="14"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                    <TextBlock Text="{Binding Title}" FontSize="12" FontWeight="Medium" Margin="2,8,2,0"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TriThu.Brush.OnSurface}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Vùng 2: thêm từ thư viện (chỉ doc CHƯA thuộc Workspace) -->
                    <TextBlock Style="{StaticResource ZoneHeader}" Text="Thêm từ thư viện" Margin="0,10,0,10"/>
                    <TextBlock Style="{StaticResource ZoneEmptyNote}"
                               Text="Mọi tài liệu trong thư viện đã thuộc Workspace này."
                               Visibility="{Binding LibraryAdditions.Count, Converter={StaticResource CountToInverseVisibilityConverter}}"/>
                    <ItemsControl ItemsSource="{Binding LibraryAdditions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Width="132" Margin="0,0,14,16">
                                    <Border Style="{StaticResource TriThu.LibraryCard}" Height="170"
                                            Background="{Binding Converter={StaticResource LibraryCoverBrushConverter}}">
                                        <TextBlock Text="{Binding Title}" Foreground="White" FontSize="13" FontWeight="Bold"
                                                   TextWrapping="Wrap" Margin="10" VerticalAlignment="Bottom"/>
                                    </Border>
                                    <Button Style="{StaticResource MaterialDesignOutlinedButton}" Margin="0,8,0,0"
                                            materialDesign:ButtonAssist.CornerRadius="12"
                                            Command="{Binding DataContext.AddFromLibraryCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="Plus" Width="14" Height="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Thêm" Margin="6,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Border>
</UserControl>
